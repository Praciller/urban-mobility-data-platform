API_HOST=127.0.0.1
API_PORT=8000
API_BIND_HOST=127.0.0.1
WEB_PORT=5173
POSTGRES_BIND_HOST=127.0.0.1
DAGSTER_HOME=.dagster
LOG_LEVEL=INFO
DOCKER_IMAGE=urban-mobility-data-platform:local
